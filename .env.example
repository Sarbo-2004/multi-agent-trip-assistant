# Multi-Agent Trip Planning Assistant Environment Variables

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# OpenWeatherMap API
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Visual Crossing Weather API
VISUAL_CROSSING_API_KEY=your-visual-crossing-api-key-here

# Geoapify Places API
GEOAPIFY_API_KEY=your-geoapify-api-key-here

# OpenRouteService API
OPENROUTESERVICE_API_KEY=your-openrouteservice-api-key-here

# App Configuration
APP_ENV=development
DEBUG=true